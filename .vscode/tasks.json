{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Initialize, Build, and Run raylib",
            "type": "shell",
            "command": "cmake -G \"MinGW Makefiles\" -S . -B build && make -C build run -j ${env:NUMBER_OF_PROCESSORS}",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}